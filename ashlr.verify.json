{
  "schemaVersion": 1,
  "mode": "replace-detected",
  "commands": [
    {
      "id": "typecheck",
      "kind": "typecheck",
      "cmd": ["bun", "run", "typecheck"],
      "cwd": ".",
      "timeoutMs": 180000,
      "required": true,
      "profiles": ["quick", "merge"]
    },
    {
      "id": "lint",
      "kind": "lint",
      "cmd": ["bun", "run", "lint"],
      "cwd": ".",
      "timeoutMs": 180000,
      "required": true,
      "profiles": ["merge"]
    },
    {
      "id": "build",
      "kind": "build",
      "cmd": ["bun", "run", "build"],
      "cwd": ".",
      "timeoutMs": 180000,
      "required": true,
      "profiles": ["merge"]
    },
    {
      "id": "package-dry-run",
      "kind": "build",
      "cmd": ["npm", "publish", "--access", "public", "--dry-run"],
      "cwd": ".",
      "timeoutMs": 180000,
      "required": true,
      "profiles": ["merge"]
    },
    {
      "id": "test-coverage",
      "kind": "test",
      "cmd": ["env", "MORPHKIT_NO_AI=1", "bun", "test", "--coverage"],
      "cwd": ".",
      "timeoutMs": 300000,
      "required": true,
      "profiles": ["merge"]
    }
  ]
}
